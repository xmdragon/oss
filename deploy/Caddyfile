# Ozon 图片暂存 —— Caddy 反代配置
# 部署时由 install.sh 复制到 /etc/caddy/Caddyfile
# {$PUBLIC_HOST} / {$ACME_EMAIL} 来自 systemd drop-in 的 /opt/oss/.env

{
    email {$ACME_EMAIL}
    # 全局请求体上限 20MB（单张图 ≤10MB，留 header/余量）
    # 防止异常大文件灌爆磁盘
    servers {
        max_header_size 1MB
    }
}

{$PUBLIC_HOST} {
    encode zstd gzip

    # 限制请求体 20MB
    request_body {
        max_size 20MB
    }

    # MinIO S3 API 反代（MinIO 绑在 127.0.0.1:9000，只本机可达）
    reverse_proxy 127.0.0.1:9000 {
        transport http {
            read_timeout 5m
            write_timeout 5m
        }
        # S3 签名校验需要原始 Host
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }

    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, HEAD, PUT"
        Access-Control-Allow-Headers "Authorization, Content-Type, Content-MD5, x-amz-*"
        Strict-Transport-Security "max-age=31536000"
        # 对象返回时不暴露 MinIO 版本头
        -Server
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 4
            roll_keep_for 720h
        }
        format json
    }
}

# ─── MinIO Console 管理端 ──────────────────────────────────
# 同域名 + 端口 9443，https 访问：https://oss.hjdtrading.com:9443
# 登录用 .env 里的 MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# LE 签发沿用 :80 HTTP-01 挑战，同一张证书即可
{$PUBLIC_HOST}:9443 {
    reverse_proxy 127.0.0.1:9001 {
        transport http {
            read_timeout 5m
            write_timeout 5m
        }
        # Console 依赖 Host 头做跳转/WebSocket；X-Forwarded-* Caddy 默认会带
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        # MinIO Console 的 WebSocket Origin 校验不接受带端口的 Origin（已知 quirk）。
        # 浏览器连 :9443 必然带 Origin: https://oss.hjdtrading.com:9443 → 403。
        # 把 Origin 改写成无端口版本，WS 才能 101 Switching Protocols。
        # Cookie 是 HttpOnly + SameSite=Lax，攻击者跨站请求不会带 auth cookie，
        # 所以即便改写了 Origin 仍不构成 CSRF 可利用性。
        header_up Origin "https://{$PUBLIC_HOST}"
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        -Server
    }

    log {
        output file /var/log/caddy/admin-access.log {
            roll_size 50mb
            roll_keep 4
        }
        format json
    }
}

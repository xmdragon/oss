# /opt/oss/admin.env —— oss-admin（Web 管理控制台）凭据 + 配置
#
# **不要手工写**：本文件由 `oss-admin setup` 交互式生成（含 bcrypt 密码 hash + TOTP
# 密钥 + 32 字节随机 session secret）。本 .example 只用于字段文档 + 应急修复参考。
#
# 用法：
#   sudo install -m 0755 deploy/oss-admin/bin/oss-admin /usr/local/bin/oss-admin
#   sudo -u oss-admin oss-admin setup           # 交互生成 admin.env
#   sudo systemctl enable --now oss-admin       # 起服务
#
# 改密：
#   sudo -u oss-admin oss-admin setup --password-only    # 只改密码 + hash
#
# 文件权限：必须 0600 owner=oss-admin（systemd 跑 oss-admin user，root 读不到也无所谓）。
# /etc/systemd/system/oss-admin.service 启动前 AssertFileNotEmpty 检查；缺失直接拒启。

# ─── 凭据 ───────────────────────────────────────────────
# 管理员用户名（登录控制台用）。建议非通用名（不要 admin/root）
ADMIN_USERNAME=grom
# bcrypt password hash（cost 10+），由 oss-admin setup 生成。绝不可写明文密码
ADMIN_PASSWORD_HASH=$2a$10$EXAMPLE_REPLACE_WITH_REAL_BCRYPT_HASH_60chars_long_xxxxxxx
# TOTP base32 secret，由 oss-admin setup 生成。空值 = 不启用 TOTP（不推荐）
ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXPEXAMPLE

# ─── 会话 ───────────────────────────────────────────────
# 32 字节 hex（openssl rand -hex 32），oss-admin setup 自动生成。
# 改这值会让所有在线管理员被强踢下线
SESSION_SECRET=CHANGE_ME_64_hex_chars_total_32_bytes_random_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── 服务 ───────────────────────────────────────────────
# oss-admin HTTP 监听地址（loopback only，由 caddy `ossmanage.hjdtrading.com` 反代）
LISTEN_ADDR=127.0.0.1:9002
# 审计日志路径（操作记录：登录 / 改 bucket / 改 user / 改 policy 等）
AUDIT_LOG_PATH=/var/log/oss-admin/audit.log

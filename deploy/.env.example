# Ozon 图片暂存 —— 环境变量
# 复制为 /opt/oss/.env 后按实际改值；.env 禁止提交 git
# 该文件同时被 systemd (EnvironmentFile) 和 bash 脚本 (source) 加载，
# 值里禁止出现空格、引号、# 等 shell 特殊字符；secret 建议用
#   openssl rand -hex 24
# 生成（纯 hex，绝对安全）。

# ─── 公网访问 ─────────────────────────────────────────────
# 三个对外域名各自独立解耦，多区域部署时各节点用自己的 .env 区分：
#   oss   节点：PUBLIC_HOST=oss.hjdtrading.com    ADMIN_HOST=ossmanage.hjdtrading.com    IMAGE_API_HOST=ai.hjdtrading.com
#   oss-kr 节点：PUBLIC_HOST=oss-kr.hjdtrading.com ADMIN_HOST=ossmanage-kr.hjdtrading.com IMAGE_API_HOST=ai-kr.hjdtrading.com
PUBLIC_HOST=oss.hjdtrading.com
# MinIO 管理端子域名（443 端口，灰云直连，LE 自动签证）
ADMIN_HOST=ossmanage.hjdtrading.com
# image-api 子域名（443 端口，灰云直连，LE 自动签证）
IMAGE_API_HOST=ai.hjdtrading.com
ACME_EMAIL=xm.dragon@gmail.com

# ─── MinIO 根账号（仅 VPS 上用，不发给任何客户端）──────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_32byte_random_hex

# ─── 桌面端 (legacy 批量上架) AK/SK（init-bucket.sh 会建用户）────
# 绑 put-only policy，只允许 PUT 到 products/*
DESKTOP_ACCESS_KEY=ozon-desktop
DESKTOP_SECRET_KEY=CHANGE_ME_32byte_random_hex

# ─── image-api AK/SK（init-bucket.sh 会建用户） ─────────────
# 绑 scoped-rw-ai-image policy，PUT/GET ai-image/*
# 与 image-api/.env 的 OSS_ACCESS_KEY / OSS_SECRET_KEY 必须一致；
# 改动需同步两边 + 重启 image-api-{web,worker}
AI_IMAGE_ACCESS_KEY=ai-image-key
AI_IMAGE_SECRET_KEY=CHANGE_ME_32byte_random_hex

# ─── Buckets ─────────────────────────────────────────────
# 拓扑（4 个 bucket + lifecycle）写在 init-bucket.sh 顶部 BUCKETS / EXTRA_RULES，
# 不再用 BUCKET_NAME / LIFECYCLE_EXPIRE_DAYS 单值变量。改 bucket 改脚本即可。

# ─── MinIO 运行参数（供 systemd unit 用，一般不用改）──────
MINIO_VOLUMES="/opt/oss/data"
# 带空格的值必须加引号（bash source 需要；systemd EnvironmentFile 也兼容）
MINIO_OPTS="--address 127.0.0.1:9000 --console-address 127.0.0.1:9001"

# ─── 备注：MinIO 自带 Console 仍跑在 127.0.0.1:9001（loopback only） ──
# 公网管理 UI 改由 oss-admin 提供（监听 127.0.0.1:9002，Caddy 反代）。
# 紧急情况下可 SSH 隧道访问官方 Console：
#   ssh -L 9001:127.0.0.1:9001 root@vps
# 这种情况下不需要 MINIO_BROWSER_REDIRECT_URL；浏览器直接走
# http://localhost:9001。

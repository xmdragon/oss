# Ozon 图片暂存服务 —— 环境变量
# 复制为 .env 后按实际改值；.env 禁止提交 git

# ─── 公网访问 ──────────────────────────────────────────────
# 你给这台 VPS 配的公网域名（必须先做 DNS A 记录指向 VPS IP）
PUBLIC_HOST=img-stage.example.com
# Let's Encrypt 证书到期提醒邮箱
ACME_EMAIL=you@example.com

# ─── MinIO 根账号 ─────────────────────────────────────────
# 只在 VPS 上用（管理 bucket / policy），不给桌面端
MINIO_ROOT_USER=admin
# openssl rand -base64 24 生成
MINIO_ROOT_PASSWORD=CHANGE_ME_to_a_32_byte_random_string

# ─── 桌面端专用 AK/SK ─────────────────────────────────────
# init-bucket.sh 会用它建子用户；桌面端编译时注入
DESKTOP_ACCESS_KEY=ozon-desktop
# openssl rand -base64 24 生成
DESKTOP_SECRET_KEY=CHANGE_ME_to_another_32_byte_random_string

# ─── Bucket 设置 ──────────────────────────────────────────
BUCKET_NAME=products
# 对象存活天数，Ozon 拉图通常 1~2 天内完成，7 天保险
LIFECYCLE_EXPIRE_DAYS=7
